{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{
          "type": "command",
          "command": "bash .claude/hooks/typecheck-on-edit.sh",
          "timeout": 90,
          "statusMessage": "Running typecheck..."
        }]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm --filter @repohelm/core build:*)",
      "Bash(bash .claude/hooks/*)"
    ]
  }
}
